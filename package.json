{
  "name": "@lvce-editor/measure-memory",
  "version": "0.0.0-dev",
  "repository": {
    "type": "git",
    "url": "git@github.com:lvce-editor/measure-memory.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "build": "node scripts/build.js",
    "format": "prettier --write .",
    "lint": "eslint .",
    "measure": "node --experimental-strip-types src/measureMemory.ts",
    "measure:visible": "node --experimental-strip-types src/measureMemory.ts --no-headless",
    "test": "node --unhandled-rejections=warn --experimental-vm-modules ./node_modules/jest/bin/jest.js --detectOpenHandles --forceExit",
    "test:watch": "node --unhandled-rejections=warn --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "type-check": "tsc"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "jest": {
    "injectGlobals": false,
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "collectCoverage": true,
    "coverageThreshold": {
      "global": {
        "branches": 10,
        "functions": 15,
        "lines": 25,
        "statements": 25
      }
    }
  },
  "dependencies": {
    "chrome-remote-interface": "^0.34.0",
    "execa": "^9.6.1",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@lerna/legacy-package-management": "^8.2.4",
    "@lvce-editor/eslint-config": "^8.3.0",
    "@rollup/plugin-babel": "^7.0.0",
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/express": "^5.0.6",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "lerna": "^8.2.4",
    "prettier": "^3.8.3",
    "rollup": "^4.60.2",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
